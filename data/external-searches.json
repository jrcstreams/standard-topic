{
  "searches": [
    {
      "name": "DuckDuckGo",
      "icon": "duckduckgo",
      "urlTemplate": "https://duckduckgo.com/?q={query}"
    },
    {
      "name": "Google News",
      "icon": "google-news",
      "urlTemplate": "https://news.google.com/search?q={query}"
    },
    {
      "name": "Reddit",
      "icon": "reddit",
      "urlTemplate": "https://www.reddit.com/search/?q={query}&type=link"
    },
    {
      "name": "X (Twitter)",
      "icon": "x-twitter",
      "urlTemplate": "https://x.com/search?q={query}"
    },
    {
      "name": "YouTube",
      "icon": "youtube",
      "urlTemplate": "https://www.youtube.com/results?search_query={query}"
    }
  ]
}