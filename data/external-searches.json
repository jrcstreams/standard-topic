{
  "searches": [
    {
      "name": "DuckDuckGo",
      "description": "Privacy-first web search results.",
      "icon": "duckduckgo",
      "urlTemplate": "https://duckduckgo.com/?q={query}"
    },
    {
      "name": "Google News",
      "description": "Headlines from Google's news aggregator.",
      "icon": "google-news",
      "urlTemplate": "https://news.google.com/search?q={query}"
    },
    {
      "name": "Reddit",
      "description": "Community discussions and threads.",
      "icon": "reddit",
      "urlTemplate": "https://www.reddit.com/search/?q={query}&type=link"
    },
    {
      "name": "X (Twitter)",
      "description": "Real-time posts and reactions.",
      "icon": "x-twitter",
      "urlTemplate": "https://x.com/search?q={query}"
    },
    {
      "name": "YouTube",
      "description": "Video search results.",
      "icon": "youtube",
      "urlTemplate": "https://www.youtube.com/results?search_query={query}"
    }
  ]
}