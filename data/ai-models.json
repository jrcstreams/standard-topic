{
  "models": [
    {"id":"chatgpt","name":"ChatGPT","icon":"chatgpt","urlTemplate":"https://chatgpt.com/?q={prompt}","copyOnOpen":true,"submissionMethod":"direct"},
    {"id":"perplexity","name":"Perplexity","icon":"perplexity","urlTemplate":"https://www.perplexity.ai/search?q={prompt}","copyOnOpen":true,"submissionMethod":"direct"},
    {"id":"google-ai","name":"Google AI Mode","icon":"google","urlTemplate":"https://www.google.com/search?udm=50&q={prompt}","copyOnOpen":true,"submissionMethod":"direct"},
    {"id":"gemini","name":"Gemini","icon":"gemini","urlTemplate":"https://gemini.google.com/app?q={prompt}","copyOnOpen":true,"submissionMethod":"populates"},
    {"id":"copilot","name":"Bing Copilot","icon":"copilot","urlTemplate":"https://www.bing.com/chat?q={prompt}","copyOnOpen":true,"submissionMethod":"populates"},
    {"id":"claude","name":"Claude","icon":"claude","urlTemplate":"https://claude.ai/new?q={prompt}","submissionMethod":"paste"}
  ],
  "defaultModel": "chatgpt",
  "submissionMethods": {
    "direct": {
      "label": "Direct prompt submission",
      "description": "Submitting prompts to {model} should submit the prompt directly."
    },
    "populates": {
      "label": "Prompt populates, user submits",
      "description": "Submitting prompts to {model} should load the prompt, and you'll need to submit it."
    },
    "paste": {
      "label": "No populated text, user pastes prompt",
      "description": "Submitting prompts to {model} does not load the prompt — it is copied to your clipboard so you can paste it in."
    }
  }
}
